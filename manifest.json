{
  "manifest_version": 2,
  "name": "Alignment Lines",
  "version": "1.0",
  "description": "Drag guide lines from rulers to check alignment on any webpage.",
  "permissions": [
    "activeTab",
    "tabs"
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Alignment Lines",
    "default_icon": {
      "48": "icon.svg"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
